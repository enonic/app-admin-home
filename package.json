{
  "name": "app-main",
  "version": "1.0.0",
  "description": "Enonic Main App",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/enonic/app-admin-home"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm build:dev",
    "build:prod": "pnpm run /^build:prod:.*$/",
    "build:prod:js": "cross-env BUILD_TARGET=js vite build --mode production",
    "build:prod:css": "cross-env BUILD_TARGET=css vite build --mode production",
    "build:prod:loader": "cross-env BUILD_TARGET=loader vite build --mode production",
    "build:prod:worker": "cross-env BUILD_TARGET=worker vite build --mode production",
    "build:dev": "pnpm run /^build:dev:.*$/",
    "build:dev:js": "cross-env BUILD_TARGET=js vite build --mode development",
    "build:dev:css": "cross-env BUILD_TARGET=css vite build --mode development",
    "build:dev:loader": "cross-env BUILD_TARGET=loader vite build --mode development",
    "build:dev:worker": "cross-env BUILD_TARGET=worker vite build --mode development",
    "check": "pnpm run /^check:.*$/",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint . --quiet --cache",
    "fix": "eslint --fix **/*.ts"
  },
  "dependencies": {
    "@enonic/lib-admin-ui": "link:.xp/dev/lib-admin-ui",
    "dompurify": "~3.3.1",
    "jquery": "^4.0.0",
    "jquery-ui": "^1.14.2",
    "mousetrap": "^1.6.5",
    "q": "^1.5.1"
  },
  "devDependencies": {
    "@enonic/eslint-config": "^2.1.0",
    "@rollup/plugin-inject": "^5.0.5",
    "@types/q": "^1.5.8",
    "autoprefixer": "^10.4.21",
    "browserslist-config-enonic": "^1.0.8",
    "cross-env": "^10.0.0",
    "cssnano": "^8.0.2",
    "enonic-admin-artifacts": "^2.3.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jiti": "^2.5.1",
    "less": "^4.6.0",
    "postcss": "^8.5.6",
    "postcss-sort-media-queries": "^6.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.1.4"
  },
  "browserslist": [
    "extends browserslist-config-enonic"
  ],
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">= 24.15.0",
    "pnpm": ">= 10.33.4"
  }
}
